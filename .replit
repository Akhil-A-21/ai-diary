modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 node_modules/.bin/tsx artifacts/api-server/src/index.ts"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node_modules/.bin/vite --config artifacts/ai-diary/vite.config.ts --port 5000 --host 0.0.0.0"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[userenv]

[userenv.shared]
VAPID_PUBLIC_KEY = "BBNhP30285pv7jjHehkyPX033PbJuJZHLr7yiDBtqtWmJlypgUIhgXk-dzJOs2FU25nkU48v9TS47qL4fs8lvDQ"
VAPID_PRIVATE_KEY = "Y_m5H8MPgr_WBD-03EuetyBJtAQzLTh4RztRMSFF7so"
VAPID_EMAIL = "mailto:admin@aidiary.app"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "NODE_ENV=production PORT=5000 node_modules/.bin/tsx artifacts/api-server/src/index.ts"]
build = ["bash", "-c", "rm -rf node_modules lib/db/node_modules artifacts/api-server/node_modules artifacts/ai-diary/node_modules .cache && npm install && node_modules/.bin/vite build --config artifacts/ai-diary/vite.config.ts"]
